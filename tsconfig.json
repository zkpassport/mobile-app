{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/assets/*": ["./assets/*"],
      "@/*": ["./src/*"]
    },
    "jsx": "react-native",
    "module": "esnext",
    "experimentalDecorators": true
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts", "metro.config.js"]
}
