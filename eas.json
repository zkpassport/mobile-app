{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "node": "22.11.0",
      "resourceClass": "large",
      "android": {
        "image": "ubuntu-24.04-jdk-17-ndk-r27b"
      },
      "ios": {
        "image": "macos-sequoia-15.6-xcode-26.0"
      }
    },
    "development": {
      "extends": "base",
      "distribution": "internal",
      "developmentClient": true
    },
    "internal": {
      "extends": "base",
      "distribution": "store",
      "autoIncrement": true
    },
    "preview": {
      "extends": "base",
      "distribution": "store",
      "autoIncrement": true
    },
    "production": {
      "extends": "base",
      "distribution": "store",
      "autoIncrement": true
    }
  },
  "submit": {
    "internal": {
      "ios": { "ascAppId": "6477371975" },
      "android": { "track": "internal" }
    },
    "preview": {
      "ios": { "ascAppId": "6477371975" },
      "android": { "track": "beta" }
    },
    "production": {
      "ios": { "ascAppId": "6477371975" },
      "android": { "track": "production" }
    }
  }
}
