{
  "name": "zkpassport-mobile-app",
  "main": "expo-router/entry",
  "version": "1.1.0",
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start --clear",
    "reset-project": "node ./scripts/reset-project.js",
    "version:patch": "bun run scripts/version.ts patch",
    "version:minor": "bun run scripts/version.ts minor",
    "version:sync": "bun run scripts/version.ts sync",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "coverage": "jest --coverage",
    "test": "jest",
    "test:lint": "jest --selectProjects lint",
    "eslint": "eslint src tests -f stylish",
    "check": "prettier -c src tests || (echo 'Please run \"npm run format\" to fix formatting issues.' && exit 1)",
    "format": "prettier -w src tests",
    "clean": "rm -rf node_modules ios/Pods ios/Podfile.lock && npm install",
    "expo-rebuild": "npx expo prebuild; npx expo install; npx pod-install",
    "android-release": "./scripts/build-android-release.sh",
    "eas-build-pre-install": "./scripts/eas-preinstall.sh",
    "eas-cloud-build:internal": "npx eas-cli@latest workflow:run internal.yml",
    "eas-cloud-build:preview": "npx eas-cli@latest workflow:run preview.yml",
    "eas-cloud-build:production": "npx eas-cli@latest workflow:run production.yml"
  },
